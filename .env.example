# Environment Configuration
# Copy this file to .env and fill in your own values.
# .env is gitignored and will NOT be committed to the repository.

# Your Formspree form endpoint — get this from formspree.io/forms
VITE_FORMSPREE_ENDPOINT=https://formspree.io/f/YOUR_FORM_ID

# Namespace for CountAPI submission tracking (use something unique to your deployment)
VITE_COUNTAPI_NAMESPACE=your-app-namespace

# Admin dashboard passcode
VITE_ADMIN_PASSCODE=change-me-before-deploying

# The base URL path for your GitHub Pages deployment
# Set this to your repository name with slashes, e.g. /VOC_GA-Survey/
# Or set to / if deploying to a custom domain root
VITE_BASE_PATH=/your-repo-name/
